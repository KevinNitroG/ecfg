# renovate.json
{
  "$schema": "https://docs.renovatebot.com renovate.json schema",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all minor and patch updates"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": "major updates"
    }
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10
}