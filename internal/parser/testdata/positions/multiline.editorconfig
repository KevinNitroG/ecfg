# Multiline EditorConfig file for position tracking tests
# This file has 50+ lines with varying line lengths
# to test position accuracy across different scenarios

root = true

# Section 1: Short lines
[*.txt]
charset = utf-8
end_of_line = lf

# Section 2: Medium lines
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Section 3: Long lines with verbose comments
[*.java]
# This is a very long comment line that extends beyond typical editor widths to test position tracking with longer content spans
indent_style = space
indent_size = 4
max_line_length = 120

# Section 4: Multiple properties
[*.py]
indent_style = space
indent_size = 4
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 88

# Section 5: Go files
[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

# Section 6: Configuration files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Section 7: Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Final comment to reach 50+ lines
# Line 49
# Line 50
# Line 51
# Line 52
