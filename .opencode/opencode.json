{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "/home/kevinnitro/projects/ecfg/.opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "/home/kevinnitro/projects/ecfg/.opencode/get-shit-done/*": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@upstash/context7-mcp@latest",
        "--",
        "context7-mcp"
      ],
      "enabled": true
    },
    "ddg-search": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:duckduckgo-mcp-server@latest",
        "--",
        "duckduckgo-mcp-server"
      ],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "fetch": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:mcp-fetch-server@latest",
        "--",
        "mcp-fetch-server"
      ],
      "enabled": true
    }
  }
}
